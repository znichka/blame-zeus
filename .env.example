# LLM — chat model provider (Phase 1 default: OpenAI)
LLM_API_KEY=sk-...
LLM_CHAT_MODEL=gpt-4o-mini

# LLM — embedding model (always OpenAI text-embedding-3-small; must match ingestion)
OPENAI_API_KEY=sk-...

# Postgres — superuser (used by Flyway for migrations)
POSTGRES_USER=zeus
POSTGRES_PASSWORD=olympus
POSTGRES_DB=blamezeus

# Postgres — read-only runtime user (used by core-api at query time)
POSTGRES_APP_USER=zeus_app
POSTGRES_APP_PASSWORD=app_password

# Telegram bot (Phase 2)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_BOT_USERNAME=BlameZeusBot

# core-api base URL (used by telegram-bot)
CORE_API_BASE_URL=http://core-api:8080
