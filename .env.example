# LLM — chat model provider (ADR-008: Anthropic — Claude Haiku 4.5)
# Since ADR-008 this is an Anthropic key (sk-ant-...), NOT the same as OPENAI_API_KEY below.
LLM_API_KEY=sk-ant-...
LLM_CHAT_MODEL=claude-haiku-4-5-20251001

# LLM — embedding model (always OpenAI text-embedding-3-large since ADR-013; must match ingestion).
# Embeddings stay on OpenAI, so this remains a separate OpenAI key.
OPENAI_API_KEY=sk-...
# Single source of truth for the embedding model name, shared by ingestion + core-api (ADR-006).
EMBEDDING_MODEL=text-embedding-3-large

# LLM — offline seed-data extraction (Stage 4, ADR-008: Claude Opus 4.8 via instructor).
# Consumed by ingestion/extraction/ only (not built yet) — uncomment when running Stage 4.
# ANTHROPIC_API_KEY may hold the same Anthropic key as LLM_API_KEY; it is a separate env var
# because the Python Anthropic SDK reads ANTHROPIC_API_KEY by convention.
#ANTHROPIC_API_KEY=sk-ant-...
#EXTRACTION_MODEL=claude-opus-4-8

# Postgres — superuser (used by Flyway for migrations, and by ingestion)
POSTGRES_USER=zeus
POSTGRES_PASSWORD=olympus
POSTGRES_DB=blamezeus
# Postgres host/port as seen from the host machine (ingestion runs outside the compose
# network, connecting to the Dockerized Postgres via its published port)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Postgres — read-only runtime user (used by core-api at query time)
POSTGRES_APP_USER=zeus_app
POSTGRES_APP_PASSWORD=app_password

